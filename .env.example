NODE_ENV=production
LOG_LEVEL=info

POSTGRES_DB=kommune
POSTGRES_USER=kommune
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://kommune:change_me@kommune-db:5432/kommune

KOMMUNE_PUBLIC_PORT=18080
APP_BASE_PATH=/kommune
API_BASE_PATH=/kommune/api
VITE_APP_BASE_PATH=/kommune/
VITE_API_BASE_PATH=/kommune/api

RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute
SEED_DEMO_DATA=true

GEOCODER_ENABLED=true
GEOCODER_PROVIDER=osm
GEOCODER_BASE_URL=https://nominatim.openstreetmap.org
GEOCODER_USER_AGENT=kommune-mvp/1.0 (dev@raoul.no)

LEGAL_SOURCE_PROVIDER_ENABLED=true
PUBLIC_DATASET_PROVIDER_ENABLED=true
MUNICIPALITY_SOURCE_PROVIDER_ENABLED=true

TILE_URL_TEMPLATE=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
TILE_ATTRIBUTION=Kartdata © OpenStreetMap-bidragsytere
